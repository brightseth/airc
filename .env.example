# Dormant until the registry + Body Service enablement handshake.
AIRC_DELEGATED_CREDENTIALS_ENABLED=

# Shared only between airc.chat and the authoritative slashvibe.dev registry.
# Generate independently; never reuse any JWT/session signing key.
AIRC_DELEGATED_UPSTREAM_SECRET=

# HMAC salt for privacy-preserving IP/subject rate-limit keys.
AIRC_EDGE_RATE_LIMIT_SALT=

# Required distributed, atomic rate-limit store (Upstash/Vercel KV REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
