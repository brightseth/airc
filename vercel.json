{
  "installCommand": "npm install",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/.well-known/airc",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.well-known/ai-plugin.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(.*).json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/AGENTS.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/docs/(.*).md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs/internal/:path*",
      "destination": "/404.html",
      "statusCode": 404
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/airc",
      "destination": "/api/well-known-airc"
    },
    {
      "source": "/spec",
      "destination": "/spec.html"
    },
    {
      "source": "/security",
      "destination": "/security.html"
    },
    {
      "source": "/federation",
      "destination": "/federation.html"
    },
    {
      "source": "/conformance",
      "destination": "/conformance.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/getting-started",
      "destination": "/getting-started.html"
    },
    {
      "source": "/ecosystem",
      "destination": "/ecosystem.html"
    },
    {
      "source": "/developers",
      "destination": "/developers.html"
    },
    {
      "source": "/frameworks",
      "destination": "/frameworks.html"
    },
    {
      "source": "/validate",
      "destination": "/validate.html"
    },
    {
      "source": "/extensions/x402-payments",
      "destination": "/extensions/x402.html"
    },
    {
      "source": "/extensions/erc8004-identity",
      "destination": "/extensions/erc8004.html"
    },
    {
      "source": "/extensions/mpp-payments",
      "destination": "/extensions/mpp.html"
    },
    {
      "source": "/extensions/a2a-bridge",
      "destination": "/extensions/a2a.html"
    },
    {
      "source": "/api/register",
      "destination": "/api/register.js"
    },
    {
      "source": "/api/presence",
      "destination": "/api/presence.js"
    },
    {
      "source": "/api/messages",
      "destination": "/api/messages.js"
    },
    {
      "source": "/api/consent",
      "destination": "/api/consent.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/api/federation/relay",
      "destination": "/api/federation/relay.js"
    },
    {
      "source": "/api/federation/identity",
      "destination": "/api/federation/identity.js"
    },
    {
      "source": "/api/identity/:handle/verification",
      "destination": "/api/identity/verification.js?handle=:handle"
    },
    {
      "source": "/api/identity/:handle",
      "destination": "/api/identity/[handle].js"
    }
  ]
}
